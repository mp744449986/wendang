{
  "name": "online-manual-viewer",
  "version": "1.0.0",
  "description": "在线文档浏览系统 - 支持 PDF/PPT/Word 文档上传、自动拆图、静态页面生成",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "generate": "node scripts/generate.js",
    "generate:search": "node scripts/generate-search.js",
    "migrate": "node scripts/migrate.js",
    "backup": "node scripts/backup.js"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-static": "^1.2.6",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf2pic": "^3.1.1",
    "pg": "^8.11.3",
    "sharp": "^0.33.2",
    "unzipper": "^0.10.14",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
